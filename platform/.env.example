# ===================================
# FIFA WC 2026 Intelligence Platform
# Environment Configuration
# ===================================

# Frontend (Vite uses VITE_ prefix)
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NAME="FIFA WC 2026 Intelligence"

# Backend
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database (SQLite default, upgrade to PostgreSQL later)
DATABASE_URL=sqlite:///./data/fifa_wc_2026.db
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fifa_wc_2026

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ML Model Configuration
MODEL_CACHE_DIR=./model_cache
ELO_DECAY_FACTOR=0.98
SIMULATION_DEFAULT_ITERATIONS=10000
